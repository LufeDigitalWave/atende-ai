# ============================================================
# Atende AI — environment example
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Core ---
ENVIRONMENT=development               # development | production
LOG_LEVEL=INFO
CONTACT_URL=https://wa.me/5511999999999  # link de contato exibido quando budget estoura

# --- Database ---
POSTGRES_USER=atende
POSTGRES_PASSWORD=atende               # troque em prod
POSTGRES_DB=atende_ai
DATABASE_URL=postgresql+asyncpg://atende:atende@db:5432/atende_ai

# --- LLM Provider (chat do agente) ---
LLM_PROVIDER=fake                      # fake | claude | openai
ANTHROPIC_API_KEY=                     # required if LLM_PROVIDER=claude
OPENAI_API_KEY=                        # required if LLM_PROVIDER=openai (also used by factory)
AGENT_MODEL=claude-haiku-4-5           # model for agent chat (claude-haiku-4-5 recommended)
AGENT_PROMPT_VERSION=sofia_v1          # arquivo em backend/app/agent/prompts/
AGENT_TEMPERATURE=0.4

# --- Prompt Factory (geração de perfil por nicho) ---
FACTORY_MODEL=gpt-4.1-mini             # model for niche profile generation (OpenAI)
FACTORY_MAX_NICHE_CHARS=60             # max chars for custom niche input (sanitization)

# --- Embeddings (RAG) ---
EMBEDDING_PROVIDER=fake                # fake | voyage
VOYAGE_API_KEY=                        # required if EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3

# --- Budget / guards ---
DAILY_TOKEN_BUDGET=200000              # ~R$ 5/dia em haiku 4.5; cai pra banner quando estoura
MAX_MESSAGES_PER_SESSION=30
RATE_LIMIT_SECONDS=2
RATE_LIMIT_NEW_SESSIONS_PER_IP_HOUR=5
MAX_INPUT_CHARS=500
SESSION_TTL_HOURS=24

# --- Admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin                   # troque em prod (≥ 12 chars)
JWT_SECRET=                            # required; gere com: openssl rand -hex 32
JWT_EXPIRES_HOURS=24

# --- Frontend (build-time) ---
VITE_API_URL=http://localhost:8000     # URL pública da API
